      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Prediction Requests (last 5m)",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 5, "w": 4, "x": 0, "y": 0 },
      "targets": [{ "expr": "increase(predict_requests_total[5m])", "refId": "A" }],
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "value",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [{ "color": "green" }] } }, "overrides": [] }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Prediction Errors (last 5m)",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 5, "w": 4, "x": 4, "y": 0 },
      "targets": [{ "expr": "increase(predict_errors_total[5m])", "refId": "A" }],
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "value",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green" }, { "color": "red", "value": 1 }]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Prediction Error Rate (%)",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 5, "w": 4, "x": 8, "y": 0 },
      "targets": [
        {
          "expr": "100 * increase(predict_errors_total[5m]) / clamp_min(increase(predict_requests_total[5m]), 1)",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "value",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green" }, { "color": "orange", "value": 20 }, { "color": "red", "value": 50 }]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Average Batch Size (5m)",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 5, "w": 4, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "rate(predict_batch_size_sum[5m]) / clamp_min(rate(predict_batch_size_count[5m]), 1)",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "value",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [{ "color": "green" }] } }, "overrides": [] }
    },
    {
      "id": 5,
      "type": "gauge",
      "title": "System CPU Usage",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 5, "w": 4, "x": 16, "y": 0 },
      "targets": [{ "expr": "system_cpu_usage_percent", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 100,
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green" }, { "color": "orange", "value": 70 }, { "color": "red", "value": 85 }]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 6,
      "type": "gauge",
      "title": "System Memory Usage",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 5, "w": 4, "x": 20, "y": 0 },
      "targets": [{ "expr": "system_memory_usage_percent", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 100,
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green" }, { "color": "orange", "value": 75 }, { "color": "red", "value": 90 }]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Prediction Throughput Over Time",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 5 },
      "targets": [
        { "expr": "rate(predict_requests_total[1m])", "legendFormat": "requests/sec", "refId": "A" },
        { "expr": "rate(predict_errors_total[1m])", "legendFormat": "errors/sec", "refId": "B" }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Prediction Latency (P50/P95/P99)",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 5 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(predict_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "P50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(predict_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "P95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(predict_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "P99",
          "refId": "C"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
    },
    {
      "id": 9,
      "type": "bargauge",
      "title": "Service Health Status",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 5 },
      "targets": [{ "expr": "service_health_status", "refId": "A" }],
      "options": {
        "displayMode": "basic",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "red" }, { "color": "green", "value": 1 }]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Batch Size Over Time",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 13 },
      "targets": [
        {
          "expr": "rate(predict_batch_size_sum[5m]) / clamp_min(rate(predict_batch_size_count[5m]), 1)",
          "legendFormat": "avg batch size",
          "refId": "A"
        }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Error Rate Trend",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 13 },
      "targets": [
        {
          "expr": "100 * rate(predict_errors_total[5m]) / clamp_min(rate(predict_requests_total[5m]), 0.0001)",
          "legendFormat": "error rate %",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent" }, "overrides": [] }
    }
  ],
